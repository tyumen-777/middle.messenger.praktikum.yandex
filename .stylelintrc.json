{
  "extends": [
    "stylelint-config-recommended"
  ],
  "customSyntax": "postcss-sass",
  "rules": {
    "max-nesting-depth": 5,
    "selector-class-pattern": null,
    "at-rule-no-unknown": true,
    "color-hex-case": "lower",
    "unit-no-unknown": null
  },
  "ignoreFiles": [
    "dist/*",
    ".parcel-cache/*",
    "node_modules/*"
  ]
}
